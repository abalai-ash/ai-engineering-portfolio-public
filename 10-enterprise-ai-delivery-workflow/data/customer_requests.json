      {
        "name": "support notes",
        "type": "unstructured",
        "sensitivity": "restricted"
      },
      {
        "name": "account records",
        "type": "structured",
        "sensitivity": "restricted"
      }
    ],
    "requirements": {
      "grounded_answers": true,
      "citations": true,
      "human_review": true,
      "access_control": true,
      "latency_target_ms": 2500,
      "rollback_plan": true,
      "monitoring": true
    },
    "success_metrics": [
      "answer supported by retrieved evidence",
      "correct access permissions",
      "useful answer or clear abstention",
      "response within latency target"
    ]
  },
